<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="com.example.calculadora">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.Calculadora">
        <activity
            android:name=".MainActivity"
            android:label="@string/app_name"
            android:theme="@style/Theme.Calculadora.NoActionBar">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Activity para registro de ordenes de servicio -->
        <activity
            android:name=".OrdenServicioActivity"
            android:label="@string/titulo_orden_servicio"
            android:theme="@style/Theme.Calculadora.NoActionBar"
            android:parentActivityName=".MainActivity">
            <meta-data
                android:name="android.support.PARENT_ACTIVITY"
                android:value=".MainActivity" />
        </activity>

        <!-- Activity para catalogo de servicios -->
        <activity
            android:name=".CatalogoServiciosActivity"
            android:label="@string/titulo_catalogo_servicios"
            android:theme="@style/Theme.Calculadora.NoActionBar"
            android:parentActivityName=".OrdenServicioActivity">
            <meta-data
                android:name="android.support.PARENT_ACTIVITY"
                android:value=".OrdenServicioActivity" />
        </activity>

        <!-- TechAudit 2.0 Activities -->
        <activity
            android:name=".ui.LaboratoriosActivity"
            android:label="TechAudit 2.0"
            android:theme="@style/Theme.Calculadora.NoActionBar"
            android:parentActivityName=".MainActivity">
            <meta-data
                android:name="android.support.PARENT_ACTIVITY"
                android:value=".MainActivity" />
        </activity>

        <activity
            android:name=".ui.EquiposActivity"
            android:label="Gestión de Equipos"
            android:theme="@style/Theme.Calculadora.NoActionBar"
            android:parentActivityName=".ui.LaboratoriosActivity">
            <meta-data
                android:name="android.support.PARENT_ACTIVITY"
                android:value=".ui.LaboratoriosActivity" />
        </activity>
    </application>

</manifest>