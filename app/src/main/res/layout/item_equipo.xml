<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="8dp"
    app:cardCornerRadius="8dp"
    app:cardElevation="4dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvNombreEquipo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="PC Dell Optiplex"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@android:color/black" />

            <TextView
                android:id="@+id/tvEstadoEquipo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Estado: Operativo"
                android:textSize="14sp"
                android:layout_marginTop="4dp"
                android:padding="4dp"
                android:background="@drawable/bg_servicio_seleccionado"
                android:textColor="@android:color/white" />
        </LinearLayout>

        <ImageView
            android:id="@+id/ivEditEquipo"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_gravity="center_vertical"
            android:padding="8dp"
            android:src="@android:drawable/ic_menu_edit"
            android:contentDescription="Editar equipo" />
    </LinearLayout>
</androidx.cardview.widget.CardView>
